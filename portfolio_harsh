<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Harshil Parmar — Portfolio</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --purple:#7c3aed;
  --purple-light:#a855f7;
  --purple-dark:#4c1d95;
  --pink:#d946ef;
  --text:#f5f3ff;
  --muted:#c4b5fd;
  --muted2:#7c6fa0;
}
html{scroll-behavior:smooth}
body{
  background:#0a0010;
  background-image:
    radial-gradient(ellipse 80% 60% at 20% 0%,rgba(124,58,237,0.35) 0%,transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 100%,rgba(168,85,247,0.2) 0%,transparent 60%),
    radial-gradient(ellipse 40% 40% at 60% 50%,rgba(76,29,149,0.15) 0%,transparent 70%);
  color:var(--text);
  font-family:"Segoe UI",system-ui,sans-serif;
  line-height:1.7;overflow-x:hidden;min-height:100vh;
}
body::before{
  content:"";position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events:none;z-index:0;opacity:0.4;
}
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  background:rgba(10,0,16,0.7);backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(124,58,237,0.15);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 3rem;height:64px;
}
.logo{
  font-size:20px;font-weight:700;
  background:linear-gradient(135deg,#a855f7,#ec4899);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{color:var(--muted);text-decoration:none;font-size:14px;transition:color 0.2s;position:relative}
.nav-links a::after{content:"";position:absolute;bottom:-4px;left:0;right:0;height:1px;background:var(--purple-light);transform:scaleX(0);transition:transform 0.3s}
.nav-links a:hover{color:var(--text)}
.nav-links a:hover::after{transform:scaleX(1)}

/* HERO — full width centered, no photo */
.hero{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  text-align:center;padding:100px 3rem 4rem;
  position:relative;z-index:1;
}
.hero-inner{max-width:720px}
.hero-tag{
  display:inline-flex;align-items:center;gap:8px;
  font-size:12px;letter-spacing:3px;text-transform:uppercase;
  color:var(--purple-light);margin-bottom:1.5rem;
  background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.3);
  padding:6px 16px;border-radius:100px;
}
.dot{width:6px;height:6px;border-radius:50%;background:#a855f7;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(168,85,247,0.4)}50%{opacity:0.7;box-shadow:0 0 0 6px rgba(168,85,247,0)}}
.hero h1{font-size:clamp(3rem,7vw,5.5rem);font-weight:800;line-height:1.05;margin-bottom:1.2rem;letter-spacing:-1.5px}
.hero h1 .name{
  background:linear-gradient(135deg,#c084fc 0%,#e879f9 40%,#f472b6 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.roles{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:1.5rem;justify-content:center}
.role-pill{font-size:13px;padding:5px 16px;border-radius:100px;background:rgba(124,58,237,0.12);border:1px solid rgba(168,85,247,0.25);color:var(--muted)}
.hero-desc{color:var(--muted2);font-size:17px;max-width:520px;margin:0 auto 2.5rem;line-height:1.8}
.cta-row{display:flex;gap:14px;flex-wrap:wrap;justify-content:center}
.btn{padding:12px 28px;border-radius:12px;font-size:14px;font-weight:600;text-decoration:none;cursor:pointer;transition:all 0.25s;display:inline-block;letter-spacing:0.3px}
.btn-grad{background:linear-gradient(135deg,#7c3aed,#a855f7,#d946ef);color:#fff;border:none;box-shadow:0 4px 24px rgba(168,85,247,0.35)}
.btn-grad:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(168,85,247,0.5)}
.btn-ghost{background:transparent;color:var(--muted);border:1px solid rgba(124,58,237,0.3)}
.btn-ghost:hover{border-color:var(--purple-light);color:var(--text);background:rgba(124,58,237,0.08)}

section.content{padding:5rem 3rem;max-width:1100px;margin:0 auto;position:relative;z-index:1}
.section-eyebrow{font-size:11px;letter-spacing:4px;text-transform:uppercase;color:var(--purple-light);margin-bottom:0.6rem;font-weight:600}
.section-title{font-size:2.2rem;font-weight:700;margin-bottom:3rem;letter-spacing:-0.5px}
.section-title span{background:linear-gradient(135deg,#a855f7,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.divider{height:1px;background:linear-gradient(to right,transparent,rgba(124,58,237,0.4),rgba(217,70,239,0.3),transparent);margin:0 3rem}

.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:14px}
.skill-card{background:rgba(124,58,237,0.07);border:1px solid rgba(124,58,237,0.18);border-radius:16px;padding:1.2rem 1rem;text-align:center;transition:all 0.3s;cursor:default;position:relative;overflow:hidden}
.skill-card::before{content:"";position:absolute;inset:0;background:linear-gradient(135deg,rgba(124,58,237,0.15),rgba(217,70,239,0.08));opacity:0;transition:opacity 0.3s}
.skill-card:hover{border-color:rgba(168,85,247,0.5);transform:translateY(-5px);box-shadow:0 12px 32px rgba(124,58,237,0.2)}
.skill-card:hover::before{opacity:1}
.skill-icon{font-size:26px;margin-bottom:10px;display:block}
.skill-name{font-size:13px;font-weight:600;color:var(--text);position:relative}
.skill-cat{font-size:11px;color:var(--muted2);margin-top:3px;position:relative}

.projects-list{display:grid;gap:22px}
.project-card{background:rgba(15,5,25,0.6);border:1px solid rgba(124,58,237,0.2);border-radius:20px;padding:2rem;display:grid;grid-template-columns:1fr auto;gap:1.5rem;align-items:start;transition:all 0.3s;position:relative;overflow:hidden}
.project-card::after{content:"";position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,rgba(168,85,247,0.6),rgba(217,70,239,0.4),transparent);opacity:0;transition:opacity 0.3s}
.project-card:hover{border-color:rgba(168,85,247,0.4);box-shadow:0 16px 48px rgba(124,58,237,0.15);transform:translateY(-3px)}
.project-card:hover::after{opacity:1}
.project-name{font-size:20px;font-weight:700;margin-bottom:8px;color:var(--text)}
.project-desc{color:var(--muted2);font-size:14px;line-height:1.7;margin-bottom:1rem}
.project-tags{display:flex;flex-wrap:wrap;gap:8px}
.tag{font-size:11px;padding:4px 12px;border-radius:100px;background:rgba(124,58,237,0.12);border:1px solid rgba(124,58,237,0.25);color:var(--muted);font-weight:500}
.project-badge{font-size:11px;padding:6px 14px;border-radius:100px;font-weight:600;white-space:nowrap;height:fit-content}
.badge-purple{background:rgba(124,58,237,0.2);border:1px solid rgba(124,58,237,0.4);color:#a855f7}
.badge-pink{background:rgba(217,70,239,0.15);border:1px solid rgba(217,70,239,0.35);color:#e879f9}
.badge-amber{background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.3);color:#fbbf24}

.edu-list{display:flex;flex-direction:column;gap:0}
.edu-item{display:grid;grid-template-columns:160px 1fr;gap:2rem;align-items:start;padding:2rem 0;border-bottom:1px solid rgba(124,58,237,0.1);position:relative}
.edu-item:last-child{border-bottom:none}
.edu-item::before{content:"";position:absolute;left:152px;top:2.8rem;width:10px;height:10px;border-radius:50%;background:linear-gradient(135deg,#a855f7,#ec4899);box-shadow:0 0 12px rgba(168,85,247,0.6)}
.edu-year{font-size:13px;color:var(--purple-light);font-weight:600;padding-top:4px;padding-right:1rem}
.edu-content h3{font-size:17px;font-weight:700;margin-bottom:4px}
.edu-content p{font-size:13px;color:var(--muted2)}

.contact-wrap{background:rgba(124,58,237,0.06);border:1px solid rgba(124,58,237,0.2);border-radius:24px;padding:3rem;text-align:center;position:relative;overflow:hidden}
.contact-wrap::before{content:"";position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:300px;height:300px;background:radial-gradient(circle,rgba(168,85,247,0.12),transparent 70%);pointer-events:none}
.contact-wrap h3{font-size:1.6rem;font-weight:700;margin-bottom:0.5rem}
.contact-wrap p{color:var(--muted2);margin-bottom:2rem}
.contact-links{display:flex;justify-content:center;gap:14px;flex-wrap:wrap}
.c-link{display:flex;align-items:center;gap:10px;padding:13px 24px;border-radius:14px;font-size:14px;font-weight:500;border:1px solid rgba(124,58,237,0.25);color:var(--muted);text-decoration:none;background:rgba(124,58,237,0.06);transition:all 0.25s}
.c-link svg{width:18px;height:18px;flex-shrink:0;transition:transform 0.25s}
.c-link:hover svg{transform:scale(1.2)}
.c-link.phone:hover{border-color:#25d366;color:#25d366;background:rgba(37,211,102,0.06);box-shadow:0 4px 20px rgba(37,211,102,0.1)}
.c-link.phone:hover svg path{stroke:#25d366}
.c-link.email:hover{border-color:#ea4335;color:#ea4335;background:rgba(234,67,53,0.06);box-shadow:0 4px 20px rgba(234,67,53,0.1)}
.c-link.email:hover svg rect,.c-link.email:hover svg path{stroke:#ea4335}
.c-link.li:hover{border-color:#0a66c2;color:#0a66c2;background:rgba(10,102,194,0.06);box-shadow:0 4px 20px rgba(10,102,194,0.1)}
.c-link.li:hover svg{fill:#0a66c2}
.c-link.ig:hover{border-color:#e1306c;color:#e1306c;background:rgba(225,48,108,0.06);box-shadow:0 4px 20px rgba(225,48,108,0.1)}
.c-link.ig:hover svg path,.c-link.ig:hover svg circle,.c-link.ig:hover svg rect{stroke:#e1306c}

footer{text-align:center;padding:2rem 3rem;color:var(--muted2);font-size:13px;position:relative;z-index:1;border-top:1px solid rgba(124,58,237,0.1)}
.fade-up{opacity:0;transform:translateY(30px);transition:opacity 0.65s ease,transform 0.65s ease}
.fade-up.show{opacity:1;transform:translateY(0)}
</style>
</head>
