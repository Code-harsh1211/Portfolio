<script>
const obs = new IntersectionObserver((entries)=>{
  entries.forEach((e,i)=>{
    if(e.isIntersecting) setTimeout(()=>e.target.classList.add("show"),i*90);
  });
},{threshold:0.12});
document.querySelectorAll(".fade-up").forEach(el=>obs.observe(el));
</script>
